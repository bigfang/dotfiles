# command = /opt/homebrew/bin/tmux new -A -s praha

term = xterm-256color
theme = Tomorrow Night

window-theme = auto
window-width = 216
window-height = 52

macos-titlebar-style = transparent
macos-non-native-fullscreen = true

font-size = 18
font-family = "Maple Mono Normal NF CN"

shell-integration-features = no-cursor
cursor-style = block
cursor-opacity = 0.6

background-opacity = 0.9
background-blur = 6

unfocused-split-opacity = 0.7

copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

quit-after-last-window-closed = true

## 键绑定
macos-option-as-alt = left

# 部分默认绑定
keybind = super+shift+p=toggle_quick_terminal
keybind = super+q=unbind
keybind = super+t=unbind
keybind = super+,=unbind

# 大小写
keybind = super+c=esc:c
keybind = super+u=esc:u
keybind = super+l=esc:l
# 移动
keybind = super+f=esc:f
keybind = super+b=esc:b
# 编辑
keybind = super+d=esc:d
keybind = super+w=esc:w
# 遍历
keybind = super+n=esc:n
keybind = super+p=esc:p
keybind = super+.=esc:.

# 屏幕操作
keybind = super+alt+n=scroll_page_lines:1
keybind = super+alt+p=scroll_page_lines:-1
keybind = super+alt+h=resize_split:left,10
keybind = super+alt+j=resize_split:down,10
keybind = super+alt+k=resize_split:up,10
keybind = super+alt+l=resize_split:right,10

# M-h 作为前缀
keybind = super+h>-=new_split:down
keybind = super+h>\=new_split:right
keybind = super+h>h=goto_split:left
keybind = super+h>j=goto_split:down
keybind = super+h>k=goto_split:up
keybind = super+h>l=goto_split:right
keybind = super+h>;=goto_split:previous
keybind = super+h>o=goto_split:next

keybind = super+h>super+n=new_window
keybind = super+h>n=new_tab
keybind = super+h>super+h=previous_tab
keybind = super+h>super+l=next_tab
keybind = super+h>z=toggle_split_zoom
keybind = super+h>1=goto_tab:1
keybind = super+h>2=goto_tab:2
keybind = super+h>3=goto_tab:3
keybind = super+h>4=goto_tab:4
keybind = super+h>0=last_tab
