# command = /opt/homebrew/bin/tmux new -A -s praha

term = xterm-256color
theme = Tomorrow Night

window-theme = auto
window-width = 216
window-height = 54

macos-titlebar-style = transparent
macos-non-native-fullscreen = true

font-size = 18
font-family = "Maple Mono Normal NF CN"

shell-integration-features = no-cursor
cursor-style = block
cursor-opacity = 0.6

background-opacity = 0.9
background-blur = 6

unfocused-split-opacity = 0.7

copy-on-select = clipboard
right-click-action = paste
clipboard-trim-trailing-spaces = true

quit-after-last-window-closed = true

## 键绑定
macos-option-as-alt = left

keybind = super+shift+u=toggle_quick_terminal
keybind = super+a=unbind
keybind = super+q=unbind
keybind = super+t=unbind
keybind = super+,=unbind

keybind = super+h=esc:h
keybind = super+m=esc:m
keybind = super+x=esc:x

# 大小写
keybind = super+c=esc:c
keybind = super+u=esc:u
keybind = super+l=esc:l
# 移动
keybind = super+f=esc:f
keybind = super+b=esc:b
# 编辑
keybind = super+d=esc:d
keybind = super+w=esc:w
keybind = super+t=esc:t
# 遍历
keybind = super+n=esc:n
keybind = super+p=esc:p
keybind = super+.=esc:.

# 屏幕操作
keybind = super+shift+n=scroll_page_lines:3
keybind = super+shift+p=scroll_page_lines:-3
keybind = super+alt+h=resize_split:left,10
keybind = super+alt+j=resize_split:down,10
keybind = super+alt+k=resize_split:up,10
keybind = super+alt+l=resize_split:right,10

# C-; 作为前缀
keybind = ctrl+;>-=new_split:down
keybind = ctrl+;>\=new_split:right
keybind = ctrl+;>h=goto_split:left
keybind = ctrl+;>j=goto_split:down
keybind = ctrl+;>k=goto_split:up
keybind = ctrl+;>l=goto_split:right
keybind = ctrl+;>,=goto_split:previous
keybind = ctrl+;>.=goto_split:next

keybind = ctrl+;>c=new_tab
keybind = ctrl+;>ctrl+n=new_tab

keybind = ctrl+;>p=previous_tab
keybind = ctrl+;>n=next_tab
keybind = ctrl+;>ctrl+;=next_tab
keybind = ctrl+;>ctrl+h=goto_tab:1
keybind = ctrl+;>ctrl+l=last_tab
