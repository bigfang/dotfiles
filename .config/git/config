[init]
	defaultBranch = master
[alias]
	co = checkout
	rt = restore
	sw = switch
	br = branch
	ci = commit
	st = status
	wt = worktree
	mo = submodule
	tr = subtree
	cp = cherry-pick
	zz = stash
	zp = stash pop
	zl = stash list
	rrr = rerere
	lg = log --color --graph --decorate --oneline --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset'
	lga = lg --all
	lgs = lg --stat
[pull]
	rebase = true
[merge]
	conflictstyle = zdiff3
[rerere]
	enabled = true
